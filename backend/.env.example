# Local/preview fallback only — see backend/settings.py. In deployed
# environments these are injected by the platform and this file is not read.
# Copy to backend/.env and fill in real values, or run `scripts/setup-env`.
# Never commit backend/.env.

# ---- Required (backend refuses to start without these) --------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=forge
JWT_SECRET=                            # 32+ chars — generate with: openssl rand -hex 32
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_PUBLIC_BUCKET=forge-products
SUPABASE_PRIVATE_BUCKET=forge-private

# ---- Optional (sane defaults if unset) -------------------------------------
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=43200
MEDIA_STORAGE_DRIVER=supabase          # only "supabase" is supported today
ENVIRONMENT=development                # production | staging | development
FORGE_ALLOW_DEMO_SEED=false            # must stay false when ENVIRONMENT=production
FORGE_DEMO_PASSWORD=                   # required only if FORGE_ALLOW_DEMO_SEED=true

# Shared rate-limit state across replicas (services/rate_limit.py) — omit to
# fall back to per-process in-memory limiting, fine for a single instance.
REDIS_URL=

# Error/perf monitoring — omit to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Product analytics — omit to disable.
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# "manual" (default, no email sent — staff copies the invite link) or
# "email" (services/invite_service.py) — see that module before switching.
INVITE_SERVICE_DRIVER=manual

# Where scripts/backup_db.py, restore_db.py, rotate_demo_credentials.py, and
# pull_backup_from_supabase.py read/write local backup files.
BACKUP_DIR=./backups
